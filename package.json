{
  "name": "lorenz-and-son-plumbing",
  "version": "0.1.0",
  "description": "Lorenz & Son Plumbing marketing site built with Gatsby, Tailwind CSS, and TypeScript.",
  "type": "commonjs",
  "scripts": {
    "develop": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{src,docs}/**/*.{ts,tsx,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gatsby",
    "plumbing",
    "marketing-site",
    "typescript",
    "tailwindcss"
  ],
  "author": "Lorenz & Son Plumbing",
  "license": "MIT",
  "dependencies": {
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/source-sans-pro": "^5.2.5",
    "gatsby": "^5.15.0",
    "gatsby-plugin-image": "^3.15.0",
    "gatsby-plugin-manifest": "^5.15.0",
    "gatsby-plugin-offline": "^6.15.0",
    "gatsby-plugin-react-helmet": "^6.15.0",
    "gatsby-plugin-sharp": "^5.15.0",
    "gatsby-source-filesystem": "^5.15.0",
    "gatsby-transformer-sharp": "^5.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "^4.33.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "gatsby-plugin-postcss": "^6.15.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
